# Copia questo file in keystore.properties e inserisci i valori del tuo keystore.
# NON committare keystore.properties né il file .jks/.keystore (contengono segreti).
#
# Per creare un keystore (da eseguire nella cartella android/app):
#   keytool -genkey -v -keystore release.keystore -alias release -keyalg RSA -keysize 2048 -validity 10000

storeFile=release.keystore
storePassword=LA_TUA_PASSWORD_KEYSTORE
keyAlias=release
keyPassword=LA_TUA_PASSWORD_KEY
